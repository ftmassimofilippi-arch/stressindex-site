# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service_role — usata SOLO server-side dal pannello Super Admin
# (/api/admin/*) per operazioni privilegiate (creare/cancellare utenti, reset
# password, gestione collegamenti). NON esporre al client (niente NEXT_PUBLIC_).
# La trovi in Supabase → Project Settings → API → service_role. Mai committare il valore reale.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Site
NEXT_PUBLIC_SITE_URL=https://stressindex.io

# Anthropic — usata server-side da /api/guide-chat per l'assistente della pagina /guide.
# Non esporre al client (niente prefisso NEXT_PUBLIC_). Non committare mai il valore reale.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
